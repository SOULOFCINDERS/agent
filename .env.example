# ============================================
# Agent .env 配置文件
# 复制本文件为 .env 并填入实际值:
#   cp .env.example .env
# .env 已在 .gitignore 中，不会提交到 git
# ============================================

# LLM API 配置
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=qwen-plus

# 可选: RAG 配置
# RAG_BACKEND=chromem
# EMBEDDING_MODEL=text-embedding-v3
